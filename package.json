{
  "name": "Sentinel",
  "version": "0.0.12",
  "private": true,
  "license": "Apache-2.0",
  "description": "Sentinel local-first desktop app",
  "author": "Sentinel",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": "1.3.6",
    "node": "21.7.3"
  },
  "main": "desktop/main/index.mjs",
  "scripts": {
    "preinstall": "node ./scripts/check-package-manager.mjs",
    "prepare": "lefthook install",
    "build": "node ./scripts/rebuild-node-native.mjs && node ./scripts/next-build.mjs",
    "build:desktop": "bun run build:desktop:mac",
    "build:desktop:linux": "bun run build:desktop:prepare && node ./scripts/desktop/package.mjs --platform linux --target AppImage",
    "build:desktop:mac": "bun run build:desktop:prepare && node ./scripts/desktop/package.mjs --platform mac --target dmg",
    "build:desktop:prepare": "bun run ./scripts/desktop/clean.mjs && bun run ./scripts/desktop/normalize-node-module-manifests.mjs && bun run build && bun run ./scripts/desktop/prepare-production.mjs && bun run ./scripts/desktop/rebuild-standalone-native.mjs && bun run ./scripts/desktop/prune-server.mjs && bun run ./scripts/desktop/prepare-shell.mjs",
    "build:desktop:windows": "bun run build:desktop:prepare && node ./scripts/desktop/package.mjs --platform win --target nsis",
    "audit:desktop-bundle": "node ./scripts/desktop/audit-bundle.mjs",
    "dev:desktop": "concurrently -k \"bun run dev -- --port 3232\" \"bun run ./scripts/desktop/dev-launch.mjs\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "bun x drizzle-kit push",
    "db:generate": "bun x drizzle-kit generate",
    "db:studio": "bun x drizzle-kit studio",
    "dev": "node ./scripts/rebuild-node-native.mjs && next dev --turbo",
    "preview": "node ./scripts/rebuild-node-native.mjs && node ./scripts/next-build.mjs && next start",
    "release:version:check": "node ./scripts/release/validate-release-version.mjs",
    "start": "node ./scripts/rebuild-node-native.mjs && next start",
    "test": "node ./scripts/run-tests.mjs",
    "typecheck": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.83",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/azure": "^3.0.49",
    "@ai-sdk/cohere": "^3.0.27",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/google-vertex": "^4.0.80",
    "@ai-sdk/groq": "^3.0.31",
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/moonshotai": "^2.0.12",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/react": "^3.0.118",
    "@ai-sdk/xai": "^3.0.74",
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@heroui/react": "^3.0.1",
    "@heroui/styles": "^3.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.5",
    "@iconify/react": "^6.0.2",
    "@linear/sdk": "^77.0.0",
    "@notionhq/client": "^5.13.0",
    "@octokit/rest": "^22.0.1",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pierre/diffs": "^1.1.7",
    "@slack/web-api": "^7.15.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/suggestion": "^3.20.1",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@types/turndown": "^5.0.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.116",
    "better-sqlite3": "12.6.2",
    "cmdk": "^1.1.1",
    "cronbake": "^0.4.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "highlight.js": "^11.11.1",
    "mammoth": "^1.12.0",
    "mongodb": "^7.1.0",
    "motion": "^12.35.0",
    "mysql2": "^3.20.0",
    "next": "^15.2.3",
    "node-pptx-parser": "^1.0.1",
    "node-pty": "^1.1.0",
    "node-xlsx": "^0.24.0",
    "officeparser": "^6.0.7",
    "pg": "^8.20.0",
    "ppt": "^0.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "resumable-stream": "^2.2.10",
    "rtf2text": "^1.0.1",
    "server-only": "^0.0.1",
    "shiki": "^3.23.0",
    "sileo": "^0.1.5",
    "sqlite-vec": "0.1.7-alpha.2",
    "superjson": "^2.2.1",
    "tailwind-variants": "^3.2.2",
    "turndown": "^7.2.2",
    "word-extractor": "^1.0.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.0.15",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "40.8.0",
    "electron-builder": "26.8.1",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "app.sentinel.desktop",
    "afterPack": "scripts/desktop/after-pack.cjs",
    "beforeBuild": "scripts/desktop/before-build.cjs",
    "directories": {
      "app": "dist/desktop-app",
      "buildResources": "build"
    },
    "electronDist": "node_modules/electron/dist",
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "desktop/dist/server",
        "to": "server"
      }
    ],
    "asar": true,
    "files": [
      "desktop/main/**/*",
      "desktop/preload/**/*",
      "desktop/shared/**/*",
      "scripts/desktop/constants.mjs",
      "scripts/desktop/server-manager.mjs",
      "scripts/desktop/service-manager.mjs",
      "scripts/desktop/state.mjs",
      "package.json",
      "!**/node_modules",
      "!**/node_modules/**/*",
      "!**/*.test.*",
      "!**/*.spec.*",
      "!**/*.map"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "icon": "assets/icon.icns",
      "notarize": true,
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      {
        "owner": "chaqchase",
        "provider": "github",
        "repo": "Sentinel"
      }
    ]
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  }
}
